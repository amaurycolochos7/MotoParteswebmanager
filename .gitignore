# ========================================
# ENVIRONMENT FILES - SECURITY CRITICAL
# ========================================
# NEVER commit real credentials to Git!
# Only .env.example files should be committed (with placeholders only)

# Root environment files
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local

# WhatsApp backend environment files
whatsapp-backend/.env
whatsapp-backend/.env.local
whatsapp-backend/.env.development
whatsapp-backend/.env.production

# WhatsApp session data (never commit sessions)
whatsapp-backend/.wwebjs_auth/
whatsapp-backend/.wwebjs_cache/

