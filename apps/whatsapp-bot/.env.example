# MotoPartes WhatsApp Bot — environment variables template.
# Copy to `.env` (never commit the real one) or set these in Dokploy.

# Same Postgres as the API — the bot reads/writes the whatsapp_sessions table.
DATABASE_URL="postgresql://motopartes:change-me@localhost:5432/motopartes"

# HTTP port Express listens on. Dockerfile exposes 3002.
PORT=3002

# Shared secret checked in the x-api-key header on every request except /health
# and /debug. Must match the API's WHATSAPP_API_KEY. The legacy name API_KEY
# is still accepted for backwards compatibility.
WHATSAPP_API_KEY=
# API_KEY=   # legacy alias — prefer WHATSAPP_API_KEY

# Puppeteer / Chromium. The Dockerfile installs system Chromium and wires these.
# In local dev on a machine that already has Chrome, you can leave them unset
# and Puppeteer will download its own browser.
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
CHROME_PATH=/usr/bin/chromium

# Path where whatsapp-web.js persists each mechanic's session data. In the
# container this is mounted as a Docker volume so sessions survive restarts.
WWEBJS_DATA_PATH=/app/data/wwebjs_auth
