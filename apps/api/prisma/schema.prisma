// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Phase 3 (multi-tenancy) adds these new models:
//   - Workspace        : one per taller
//   - Membership       : profile ↔ workspace (N:N with role)
//   - Plan             : free / starter / pro / business / flagship
//   - Subscription     : the workspace's current plan + Stripe refs
//   - UsageCounter     : per-workspace monthly usage for plan enforcement
//   - Invitation       : pending invites to a workspace
//   - WorkspaceAsset   : logos, PDF headers, branding uploads
//   - AuditLog         : compliance / security events
//
// Plus a nullable `workspace_id` column on every data table. Nullable for
// migration safety; in practice every row is populated by the migration
// script and every INSERT from the app path sets it via the Prisma
// extension in src/lib/prisma.js.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// MULTI-TENANCY CORE
// =============================================

model Workspace {
  id                 String    @id @default(uuid()) @db.Uuid
  slug               String    @unique                    // motopartes, taller-juarez, etc.
  name               String
  business_type      String    @default("motorcycle")
  country            String    @default("MX")
  timezone           String    @default("America/Mexico_City")
  currency           String    @default("MXN")
  folio_prefix       String    @default("MP")              // MP-, TJ-, etc. Used on order_number.
  plan_id            String?   @db.Uuid
  trial_ends_at      DateTime? @db.Timestamptz
  subscription_status String   @default("trialing")        // trialing | active | past_due | canceled | paused
  stripe_customer_id String?
  branding           Json      @default("{}")              // { logo_url, primary_color, secondary_color, tagline, pdf_footer }
  settings           Json      @default("{}")              // { business_hours, default_notification_templates, ... }
  is_active          Boolean   @default(true)
  is_flagship        Boolean   @default(false)             // motoblaker's original taller — exempt from any plan limit check
  onboarding_completed Boolean @default(false)
  created_by         String?   @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamptz
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz

  plan               Plan?             @relation(fields: [plan_id], references: [id])
  memberships        Membership[]
  invitations        Invitation[]
  assets             WorkspaceAsset[]
  subscription       Subscription?
  usage_counters     UsageCounter[]
  audit_logs         AuditLog[]

  // Every data table has a back-reference so cascade-deletes work if a
  // workspace is nuked. ON DELETE behavior is set at the table end.
  clients            Client[]
  motorcycles        Motorcycle[]
  services           Service[]
  order_statuses     OrderStatus[]
  orders             Order[]
  order_services     OrderService[]
  order_parts        OrderPart[]
  order_photos       OrderPhoto[]
  order_history      OrderHistory[]
  order_updates      OrderUpdate[]
  appointments       Appointment[]
  whatsapp_sessions  WhatsappSession[]
  order_requests     OrderRequest[]
  mechanic_earnings  MechanicEarning[]
  payment_requests   PaymentRequest[]

  @@map("workspaces")
}

model Membership {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String   @db.Uuid
  profile_id   String   @db.Uuid
  role         String   @default("mechanic") // owner | admin | mechanic | auxiliary
  permissions  Json     @default("{}")        // per-workspace override of the 9 boolean perms on Profile
  invited_by   String?  @db.Uuid
  joined_at    DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  profile   Profile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, profile_id])
  @@index([profile_id])
  @@map("memberships")
}

model Plan {
  id                      String  @id @default(uuid()) @db.Uuid
  code                    String  @unique            // free | starter | pro | business | flagship
  name                    String
  price_mxn_monthly       Int     @default(0)
  price_mxn_yearly        Int     @default(0)
  stripe_price_id_monthly String?
  stripe_price_id_yearly  String?
  features                Json    @default("{}")     // { orders_per_month, users, whatsapp_sessions, whatsapp_messages, storage_gb, branding, automations, api }
  is_public               Boolean @default(true)     // flagship is NOT public
  is_active               Boolean @default(true)
  display_order           Int     @default(0)
  created_at              DateTime @default(now()) @db.Timestamptz

  workspaces    Workspace[]
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  workspace_id           String    @unique @db.Uuid
  plan_id                String    @db.Uuid
  stripe_subscription_id String?
  status                 String    @default("trialing") // trialing | active | past_due | canceled | paused
  current_period_start   DateTime? @db.Timestamptz
  current_period_end     DateTime? @db.Timestamptz
  cancel_at              DateTime? @db.Timestamptz
  canceled_at            DateTime? @db.Timestamptz
  created_at             DateTime  @default(now()) @db.Timestamptz
  updated_at             DateTime  @default(now()) @updatedAt @db.Timestamptz

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [plan_id], references: [id])

  @@map("subscriptions")
}

model UsageCounter {
  id                String   @id @default(uuid()) @db.Uuid
  workspace_id      String   @db.Uuid
  period            String                           // "yyyy-mm"
  orders_count      Int      @default(0)
  whatsapp_messages Int      @default(0)
  storage_bytes     BigInt   @default(0)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, period])
  @@map("usage_counters")
}

model Invitation {
  id           String    @id @default(uuid()) @db.Uuid
  workspace_id String    @db.Uuid
  email        String
  role         String    @default("mechanic")
  token        String    @unique
  expires_at   DateTime  @db.Timestamptz
  accepted_at  DateTime? @db.Timestamptz
  invited_by   String?   @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@map("invitations")
}

model WorkspaceAsset {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String   @db.Uuid
  kind         String                                // logo | favicon | pdf_header | pdf_footer
  url          String
  bytes        Int      @default(0)
  mime_type    String?
  uploaded_by  String?  @db.Uuid
  uploaded_at  DateTime @default(now()) @db.Timestamptz

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, kind])
  @@map("workspace_assets")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String?  @db.Uuid
  profile_id   String?  @db.Uuid
  event        String                                // subscription.changed | user.invited | order.deleted | ...
  payload      Json     @default("{}")
  ip_address   String?
  user_agent   String?
  created_at   DateTime @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: SetNull)

  @@index([workspace_id, created_at])
  @@index([event, created_at])
  @@map("audit_logs")
}

// Raw Stripe webhook events, kept for 90 days for debugging/replay. Every
// processed event is idempotent-guarded by stripe_event_id so retries don't
// double-charge or double-downgrade.
model BillingEvent {
  id              String   @id @default(uuid()) @db.Uuid
  workspace_id    String?  @db.Uuid
  stripe_event_id String?  @unique
  event_type      String                             // e.g. "invoice.paid" | "customer.subscription.updated"
  payload         Json
  processed_at    DateTime? @db.Timestamptz
  error           String?
  created_at      DateTime @default(now()) @db.Timestamptz

  @@index([workspace_id, created_at])
  @@index([event_type, created_at])
  @@map("billing_events")
}

// Ring-buffer of failed payment attempts per workspace. Used by the dunning
// sweep: if 3+ FailedPayment rows land within 7 days and the subscription is
// still past_due, the workspace gets auto-downgraded to Free.
model FailedPayment {
  id                     String   @id @default(uuid()) @db.Uuid
  workspace_id           String   @db.Uuid
  stripe_invoice_id      String?
  stripe_payment_intent  String?
  amount_cents           Int      @default(0)
  currency               String   @default("mxn")
  reason                 String?                    // stripe's failure_reason
  created_at             DateTime @default(now()) @db.Timestamptz

  @@index([workspace_id, created_at])
  @@map("failed_payments")
}

// =============================================
// PHASE 5 — AUTOMATIONS
// =============================================

// A configurable rule in the automation engine. One Automation ties a trigger
// (event name + optional filter) to an action (what to send / do) and a
// template. Automations start disabled; the owner flips them on explicitly.
model Automation {
  id            String    @id @default(uuid()) @db.Uuid
  workspace_id  String    @db.Uuid
  name          String
  description   String?
  trigger       String                           // e.g. 'order.created'
  filter        Json      @default("{}")         // narrows the trigger
  action        String                           // 'whatsapp.send_template' | 'pdf.send_quote' | 'task.create' | 'webhook.fire'
  params        Json      @default("{}")         // action-specific (template_id, to, webhook_url, delay_minutes...)
  delay_minutes Int       @default(0)            // how long to wait after trigger before firing
  enabled       Boolean   @default(false)
  run_count     Int       @default(0)
  fail_count    Int       @default(0)
  last_run_at   DateTime? @db.Timestamptz
  last_error    String?
  is_default    Boolean   @default(false)        // one of the 7 seeded defaults
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz

  jobs          AutomationJob[]

  @@index([workspace_id, trigger, enabled])
  @@map("automations")
}

// Reusable message templates (WhatsApp and — later — email).
model MessageTemplate {
  id            String   @id @default(uuid()) @db.Uuid
  workspace_id  String   @db.Uuid
  name          String
  channel       String                          // 'whatsapp' | 'email'
  subject       String?                         // email only
  body          String                          // supports {placeholder} substitution
  is_default    Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  @@index([workspace_id])
  @@map("message_templates")
}

// Queue row — each event fires into the queue; the worker picks up pending
// rows, runs the action, marks done/failed with retry metadata.
model AutomationJob {
  id             String    @id @default(uuid()) @db.Uuid
  workspace_id   String    @db.Uuid
  automation_id  String?   @db.Uuid
  trigger_event  String
  context        Json      @default("{}")       // { order_id, client_id, motorcycle_id, ... }
  scheduled_at   DateTime  @db.Timestamptz
  status         String    @default("pending")  // pending | running | done | failed
  attempts       Int       @default(0)
  last_error     String?
  ran_at         DateTime? @db.Timestamptz
  result         Json?
  created_at     DateTime  @default(now()) @db.Timestamptz

  automation     Automation? @relation(fields: [automation_id], references: [id], onDelete: SetNull)

  @@index([status, scheduled_at])
  @@index([workspace_id, created_at])
  @@map("automation_jobs")
}

// Internal tasks — created by the `task.create` action or manually.
model Task {
  id            String    @id @default(uuid()) @db.Uuid
  workspace_id  String    @db.Uuid
  title         String
  description   String?
  assigned_to   String?   @db.Uuid              // Profile.id (optional)
  due_at        DateTime? @db.Timestamptz
  completed_at  DateTime? @db.Timestamptz
  source        String    @default("manual")    // 'manual' | 'automation'
  metadata      Json      @default("{}")        // ref to order_id etc.
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz

  @@index([workspace_id, completed_at])
  @@index([assigned_to, completed_at])
  @@map("tasks")
}

// =============================================
// 1. PERFILES DE USUARIO
// =============================================
model Profile {
  id                    String   @id @default(uuid()) @db.Uuid
  email                 String   @unique
  password_hash         String?
  full_name             String
  phone                 String?
  role                  String   @default("mechanic") // GLOBAL role — workspace-level role lives in Membership
  commission_percentage Decimal  @default(10.00) @db.Decimal(5, 2)
  is_active             Boolean  @default(true)
  avatar_url            String?
  is_master_mechanic    Boolean  @default(false)
  requires_approval     Boolean  @default(false)
  can_create_services   Boolean  @default(false)
  can_create_appointments Boolean @default(true)
  can_send_messages     Boolean  @default(true)
  can_create_clients    Boolean  @default(true)
  can_edit_clients      Boolean  @default(false)
  can_delete_orders     Boolean  @default(false)
  can_view_approved_orders Boolean @default(true)
  // Kept from Phase 1 self-signup; still written by /api/auth/register to help
  // surface workshop name on the admin audit log. After Phase 3 the same info
  // lives on Workspace.name as source of truth.
  workshop_name         String?
  business_type         String?  @default("motorcycle")
  signup_source         String?
  created_at            DateTime @default(now()) @db.Timestamptz
  updated_at            DateTime @default(now()) @updatedAt @db.Timestamptz

  memberships           Membership[]

  // Relations
  created_clients       Client[]          @relation("ClientCreator")
  motorcycles_assigned  Order[]           @relation("OrderMechanic")
  orders_approved       Order[]           @relation("OrderApprover")
  uploaded_photos       OrderPhoto[]
  appointments_assigned Appointment[]     @relation("AppointmentMechanic")
  appointments_created  Appointment[]     @relation("AppointmentCreator")
  order_history         OrderHistory[]
  earnings              MechanicEarning[]
  whatsapp_sessions     WhatsappSession[]

  // Order Requests
  requests_sent         OrderRequest[]    @relation("RequestSender")
  requests_received     OrderRequest[]    @relation("RequestReceiver")

  // Payment Requests
  payments_sent         PaymentRequest[]  @relation("PaymentSender")
  payments_received     PaymentRequest[]  @relation("PaymentReceiver")

  @@map("profiles")
}

// =============================================
// 2. CLIENTES
// =============================================
model Client {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String?  @db.Uuid
  phone        String
  full_name    String
  email        String?
  notes        String?
  created_by   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz

  workspace    Workspace?    @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator      Profile?      @relation("ClientCreator", fields: [created_by], references: [id])
  motorcycles  Motorcycle[]
  orders       Order[]
  appointments Appointment[]

  // Phone can repeat across workspaces (each taller has its own list).
  @@unique([workspace_id, phone])
  @@index([workspace_id])
  @@map("clients")
}

// =============================================
// 3. MOTOCICLETAS
// =============================================
model Motorcycle {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String?  @db.Uuid
  client_id    String   @db.Uuid
  brand        String
  model        String
  year         Int?
  plates       String?
  color        String?
  vin          String?
  mileage      Int      @default(0)
  notes        String?
  created_at   DateTime @default(now()) @db.Timestamptz

  workspace    Workspace?    @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  orders       Order[]
  appointments Appointment[]

  @@index([workspace_id])
  @@map("motorcycles")
}

// =============================================
// 4. CATÁLOGO DE SERVICIOS
// =============================================
model Service {
  id             String   @id @default(uuid()) @db.Uuid
  workspace_id   String?  @db.Uuid
  name           String
  description    String?
  base_price     Decimal  @db.Decimal(10, 2)
  labor_cost     Decimal  @default(0) @db.Decimal(10, 2)
  materials_cost Decimal  @default(0) @db.Decimal(10, 2)
  category       String   @default("general")
  is_active      Boolean  @default(true)
  display_order  Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz

  workspace      Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  order_services OrderService[]

  @@index([workspace_id])
  @@map("services")
}

// =============================================
// 5. ESTADOS DE ÓRDENES
// =============================================
model OrderStatus {
  id            String   @id @default(uuid()) @db.Uuid
  workspace_id  String?  @db.Uuid
  name          String
  description   String?
  color         String   @default("#3b82f6")
  display_order Int      @default(0)
  is_terminal   Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  orders    Order[]

  // Status names are unique PER WORKSPACE (not globally), so each taller can
  // customize labels if they want.
  @@unique([workspace_id, name])
  @@index([workspace_id])
  @@map("order_statuses")
}

// =============================================
// 6. ÓRDENES DE SERVICIO
// =============================================
model Order {
  id                  String    @id @default(uuid()) @db.Uuid
  workspace_id        String?   @db.Uuid
  order_number        String    @unique
  client_id           String?   @db.Uuid
  motorcycle_id       String?   @db.Uuid
  mechanic_id         String?   @db.Uuid
  approved_by         String?   @db.Uuid
  status_id           String?   @db.Uuid
  customer_complaint  String?
  initial_diagnosis   String?
  mechanic_notes      String?
  labor_total         Decimal   @default(0) @db.Decimal(10, 2)
  parts_total         Decimal   @default(0) @db.Decimal(10, 2)
  total_amount        Decimal   @default(0) @db.Decimal(10, 2)
  advance_payment     Decimal   @default(0) @db.Decimal(10, 2)
  payment_method      String?
  is_paid             Boolean   @default(false)
  paid_at             DateTime? @db.Timestamptz
  public_token        String?   @unique
  client_link         String?
  client_last_seen_at DateTime? @db.Timestamptz
  link_sent_at        DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @default(now()) @updatedAt @db.Timestamptz
  completed_at        DateTime? @db.Timestamptz

  workspace    Workspace?        @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  client       Client?           @relation(fields: [client_id], references: [id])
  motorcycle   Motorcycle?       @relation(fields: [motorcycle_id], references: [id])
  mechanic     Profile?          @relation("OrderMechanic", fields: [mechanic_id], references: [id])
  approver     Profile?          @relation("OrderApprover", fields: [approved_by], references: [id])
  status       OrderStatus?      @relation(fields: [status_id], references: [id])
  services     OrderService[]
  parts        OrderPart[]
  photos       OrderPhoto[]
  history      OrderHistory[]
  updates      OrderUpdate[]
  earnings     MechanicEarning[]

  @@index([workspace_id])
  @@map("orders")
}

// =============================================
// 7. SERVICIOS POR ORDEN
// =============================================
model OrderService {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String?  @db.Uuid
  order_id     String   @db.Uuid
  service_id   String?  @db.Uuid
  name         String
  price        Decimal  @db.Decimal(10, 2)
  cost         Decimal  @default(0) @db.Decimal(10, 2)
  quantity     Int      @default(1)
  notes        String?
  created_at   DateTime @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  order     Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  service   Service?   @relation(fields: [service_id], references: [id])

  @@index([workspace_id])
  @@map("order_services")
}

// =============================================
// 8. REFACCIONES POR ORDEN
// =============================================
model OrderPart {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String?  @db.Uuid
  order_id     String   @db.Uuid
  name         String
  part_number  String?
  cost         Decimal  @db.Decimal(10, 2)
  price        Decimal  @db.Decimal(10, 2)
  quantity     Int      @default(1)
  notes        String?
  created_at   DateTime @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  order     Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@map("order_parts")
}

// =============================================
// 9. FOTOS DE ÓRDENES
// =============================================
model OrderPhoto {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String?  @db.Uuid
  order_id     String   @db.Uuid
  url          String
  category     String?
  caption      String?
  uploaded_by  String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  order     Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  uploader  Profile?   @relation(fields: [uploaded_by], references: [id])

  @@index([workspace_id])
  @@map("order_photos")
}

// =============================================
// 10. HISTORIAL DE CAMBIOS
// =============================================
model OrderHistory {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String?  @db.Uuid
  order_id     String   @db.Uuid
  changed_by   String?  @db.Uuid
  old_status   String?
  new_status   String
  notes        String?
  created_at   DateTime @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  order     Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  changer   Profile?   @relation(fields: [changed_by], references: [id])

  @@index([workspace_id])
  @@map("order_history")
}

// =============================================
// 11. ACTUALIZACIONES DE ORDEN
// =============================================
model OrderUpdate {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String?  @db.Uuid
  order_id     String   @db.Uuid
  title        String
  message      String?
  created_by   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  order     Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@map("order_updates")
}

// =============================================
// 12. CITAS/RECORDATORIOS
// =============================================
model Appointment {
  id                   String   @id @default(uuid()) @db.Uuid
  workspace_id         String?  @db.Uuid
  client_id            String?  @db.Uuid
  motorcycle_id        String?  @db.Uuid
  assigned_mechanic_id String?  @db.Uuid
  scheduled_date       DateTime @db.Timestamptz
  service_type         String?
  notes                String?
  status               String   @default("scheduled")
  reminder_sent        Boolean  @default(false)
  created_by           String?  @db.Uuid
  created_at           DateTime @default(now()) @db.Timestamptz

  workspace  Workspace?  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  client     Client?     @relation(fields: [client_id], references: [id])
  motorcycle Motorcycle? @relation(fields: [motorcycle_id], references: [id])
  mechanic   Profile?    @relation("AppointmentMechanic", fields: [assigned_mechanic_id], references: [id])
  creator    Profile?    @relation("AppointmentCreator", fields: [created_by], references: [id])

  @@index([workspace_id])
  @@map("appointments")
}

// =============================================
// 13. SESIÓN WHATSAPP
// =============================================
model WhatsappSession {
  id              String    @id @default(uuid()) @db.Uuid
  workspace_id    String?   @db.Uuid
  mechanic_id     String?   @unique @db.Uuid
  is_connected    Boolean   @default(false)
  phone_number    String?
  session_name    String?
  connected_at    DateTime? @db.Timestamptz
  disconnected_at DateTime? @db.Timestamptz
  last_heartbeat  DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  mechanic  Profile?   @relation(fields: [mechanic_id], references: [id])

  @@index([workspace_id])
  @@map("whatsapp_sessions")
}

// =============================================
// 14. SOLICITUDES DE ORDEN (Auxiliar → Maestro)
// =============================================
model OrderRequest {
  id               String    @id @default(uuid()) @db.Uuid
  workspace_id     String?   @db.Uuid
  requested_by     String    @db.Uuid
  requested_to     String    @db.Uuid
  order_data       Json?
  status           String    @default("pending")
  response_notes   String?
  responded_at     DateTime? @db.Timestamptz
  created_order_id String?   @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  requester Profile    @relation("RequestSender",   fields: [requested_by], references: [id])
  approver  Profile    @relation("RequestReceiver", fields: [requested_to], references: [id])

  @@index([workspace_id])
  @@map("order_requests")
}

// =============================================
// 15. GANANCIAS DE MECÁNICOS
// =============================================
model MechanicEarning {
  id                 String    @id @default(uuid()) @db.Uuid
  workspace_id       String?   @db.Uuid
  order_id           String    @db.Uuid
  mechanic_id        String    @db.Uuid
  labor_amount       Decimal   @default(0) @db.Decimal(10, 2)
  commission_rate    Decimal   @default(0) @db.Decimal(5, 2)
  earned_amount      Decimal   @default(0) @db.Decimal(10, 2)
  is_paid            Boolean   @default(false)
  paid_at            DateTime? @db.Timestamptz
  week_start         DateTime? @db.Timestamptz
  payment_request_id String?   @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  order     Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  mechanic  Profile    @relation(fields: [mechanic_id], references: [id])

  @@index([workspace_id])
  @@map("mechanic_earnings")
}

// =============================================
// 16. SOLICITUDES DE PAGO (Maestro → Auxiliar)
// =============================================
model PaymentRequest {
  id            String    @id @default(uuid()) @db.Uuid
  workspace_id  String?   @db.Uuid
  master_id     String    @db.Uuid
  auxiliary_id  String    @db.Uuid
  total_amount  Decimal   @default(0) @db.Decimal(10, 2)
  earning_ids   Json?
  order_details Json?
  status        String    @default("pending")
  notes         String?
  accepted_at   DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  master    Profile    @relation("PaymentSender",   fields: [master_id],    references: [id])
  auxiliary Profile    @relation("PaymentReceiver", fields: [auxiliary_id], references: [id])

  @@index([workspace_id])
  @@map("payment_requests")
}
