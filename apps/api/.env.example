# MotoPartes API — environment variables template.
# Copy to `.env` (never commit the real one) or set these in Dokploy → app → Environment.

# PostgreSQL connection string. In production this points to the Dokploy-managed
# postgres service; in local dev use the compose DB (see docker-compose.yml at repo root).
DATABASE_URL="postgresql://motopartes:change-me@localhost:5432/motopartes"

# HTTP port Fastify listens on. Dockerfile exposes 3000.
PORT=3000

# JWT signing secret. REQUIRED in production — the server logs a loud warning
# if this is unset and falls back to a legacy default. Rotate to a long random
# string (e.g., openssl rand -hex 64). Rotating invalidates every existing session.
JWT_SECRET=

# Shared secret the API sends in the x-api-key header when calling the bot.
# Must exactly match the bot's WHATSAPP_API_KEY (or API_KEY) value.
WHATSAPP_API_KEY=

# Internal URL where the WhatsApp bot is reachable from the API container.
# In production this is the Dokploy service name on the swarm overlay.
WHATSAPP_BOT_INTERNAL_URL="http://app-calculate-cross-platform-monitor-n39v21:3002"

# Extra origins (comma-separated) that the API's CORS middleware should accept,
# on top of motopartes.cloud and localhost.
CORS_ORIGINS=

# Legacy Supabase credentials used only by the dormant /api/admin/migrate-motos
# endpoint. Leave unset unless you need to re-run the Supabase→Postgres data
# import. The endpoint itself is gated behind requireAdmin.
SUPABASE_LEGACY_PROJECT_ID=
SUPABASE_LEGACY_SERVICE_KEY=
