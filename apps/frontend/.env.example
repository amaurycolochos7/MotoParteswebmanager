# MotoPartes Frontend — environment variables template.
# Vite reads variables prefixed with VITE_ at build time only.

# Base URL of the API. Local dev defaults to `/api` which Vite proxies to the
# API container (see vite.config.js). In production the compiled bundle uses
# a relative `/api` served by nginx which proxies to the API service.
VITE_API_URL=/api

# Base URL of the WhatsApp bot proxy route exposed by nginx + the API.
VITE_WHATSAPP_BOT_URL=/api/whatsapp-bot

# Shared secret the FRONTEND would send to the bot in case it ever calls the
# bot directly from the browser. All current traffic goes API→bot, so this is
# rarely used. Must match WHATSAPP_API_KEY if set.
VITE_WHATSAPP_BOT_KEY=
